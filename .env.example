# Environnement — Heritage

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=heritage
POSTGRES_USER=heritage
POSTGRES_PASSWORD=heritage_pass

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_pass

# Redis
REDIS_URL=redis://redis:6379

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=heritage_access
MINIO_SECRET_KEY=heritage_secret
MINIO_BUCKET=heritage-media

# Services URLs (for gateway)
AUTH_SERVICE_URL=http://service-auth:4001/graphql
TREE_SERVICE_URL=http://service-tree:4002/graphql
RECORDS_SERVICE_URL=http://service-records:4003/graphql
MEDIA_SERVICE_URL=http://service-media:4004/graphql
MATCHING_SERVICE_URL=http://service-matching:4005/graphql

